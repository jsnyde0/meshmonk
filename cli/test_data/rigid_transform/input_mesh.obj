# Test mesh for pure translation (8-point cube)
# v: vertex positions, vn: vertex normals
v 0.500000 0.500000 0.500000
v -0.500000 0.500000 0.500000
v -0.500000 -0.500000 0.500000
v 0.500000 -0.500000 0.500000
v 0.500000 0.500000 -0.500000
v -0.500000 0.500000 -0.500000
v -0.500000 -0.500000 -0.500000
v 0.500000 -0.500000 -0.500000

vn 0.577350 0.577350 0.577350
vn -0.577350 0.577350 0.577350
vn -0.577350 -0.577350 0.577350
vn 0.577350 -0.577350 0.577350
vn 0.577350 0.577350 -0.577350
vn -0.577350 0.577350 -0.577350
vn -0.577350 -0.577350 -0.577350
vn 0.577350 -0.577350 -0.577350

# f: faces (12 triangles for a cube)
f 1//1 2//2 3//3 
f 1//1 3//3 4//4 
f 5//5 8//8 7//7 
f 5//5 7//7 6//6 
f 1//1 4//4 8//8 
f 1//1 8//8 5//5 
f 2//2 6//6 7//7 
f 2//2 7//7 3//3 
f 4//4 3//3 7//7 
f 4//4 7//7 8//8 
f 1//1 5//5 6//6 
f 1//1 6//6 2//2
